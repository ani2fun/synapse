#!/usr/bin/env bash
# ── DEV LOOP ─────────────────────────────────────────────────────────────────
# axum API on :8280 (background) + Astro dev on :5373 (foreground, HMR, proxies
# /api /media /c4). Ctrl-C stops both. :5373 is pinned by the Keycloak dev realm
# origin allowlist — a silent port bump 403s the silent-SSO iframe.
set -euo pipefail
cd "$(dirname "$0")/.."

echo "──────────────────────────────────────────────────────────"
echo "  synapse dev loop"
echo "  branch: $(git branch --show-current)   api :${SYNAPSE_PORT:-8280}   web :5373"
echo "──────────────────────────────────────────────────────────"


# shellcheck source=lib-ports.sh
source "$(dirname "$0")/lib-ports.sh"
reclaim "${SYNAPSE_PORT:-8280}" "synapse-server"
reclaim 5373 "astro-dev"

# The viz wasm bundle (A10): Vite resolves the lazy import on demand, so a missing pkg only
# explodes the first time a page actually loads viz — build it up front (dev profile, seconds
# when warm) so the loop never serves that surprise.
if [[ ! -f web/src/lib/viz-wasm/pkg/viz_wasm.js ]]; then
  ./dev-tools/build-viz-wasm.sh dev
fi

cargo build -p synapse-server --quiet
./target/debug/synapse-server &
SERVER_PID=$!
trap 'kill "$SERVER_PID" 2>/dev/null || true' EXIT

cd web && exec npx astro dev
