{
  "name": "synapse-rs-client",
  "private": true,
  "type": "module",
  "scripts": {
    "wasm": "wasm-pack build . --dev --target web --out-dir pkg --out-name synapse_client",
    "wasm:release": "wasm-pack build . --release --target web --out-dir pkg --out-name synapse_client",
    "dev": "npm run wasm && vite",
    "build": "npm run wasm:release && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
